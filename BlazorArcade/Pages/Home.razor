@page "/"
@inject NavigationManager _nav
<video muted loop id="bg">
    <source src="./css/BGTunnel.mp4" type="video/mp4" />
</video>

@if (GameNr == 0)
{
    <h3 class="white">Welcome to the Arcade!</h3>
    <p class="white">Choose a game to play:</p>
}
<div class="game-selection">
    <button @onclick="@(() => _nav.NavigateTo("/Tetris"))">Tetris</button>
    <button @onclick="@(() => _nav.NavigateTo("/Breakout"))">Breakout</button>
    <button @onclick="@(() => _nav.NavigateTo("/Sudoku"))">Sudoku</button>
    <button @onclick="@(() => _nav.NavigateTo("/Pacman"))">Pacman</button>
    <button @onclick="@(() => _nav.NavigateTo("/2048"))">2048</button>
    <button @onclick="@(() => _nav.NavigateTo("/Platformer"))">Platformer</button>
    <button @onclick="@(() => _nav.NavigateTo("/Chess"))">Chess</button>
</div>
