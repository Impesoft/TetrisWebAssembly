@page "/Pacman"
@namespace BlazorArcade.Pages
@inject NavigationManager _nav

<video muted loop id="bg">
    <source src="./css/BGTunnel.mp4" type="video/mp4" />
</video>

<div class="controls">
    <button @onclick="@(() => _nav.NavigateTo("/"))">Home</button>
    @if (GameTimer == null)
    {
        <button @onclick="StartGame">Start</button>
    }
    else
    {
        <button @onclick="PauseGame">Pause</button>
    }
</div>

<div class="pacman-container" tabindex="0" 
     @onkeydown="HandleKeyDown" 
     @ontouchstart="HandleTouchStart" 
     @ontouchend="HandleTouchEnd" 
     @ref="GameContainer">
     
    <div class="stats-container">
        <span>Score: @GameInstance.Score</span>
        <span>Lives: @GameInstance.Lives</span>
    </div>

    @if (GameInstance.IsGameOver)
    {
        <div class="game-message">
            <h2>Game Over!</h2>
            <button @onclick="StartGame">Restart</button>
        </div>
    }
    else if (GameInstance.IsGameWon)
    {
        <div class="game-message">
            <h2>You Win!</h2>
            <button @onclick="StartGame">Play Again</button>
        </div>
    }

    <svg class="pacman-board" xmlns="http://www.w3.org/2000/svg"
         viewBox="0 0 @(GameInstance.Width * BlockSize) @(GameInstance.Height * BlockSize)">
        
        <defs>
            <radialGradient id="power-pellet">
                <stop offset="0%" stop-color="white" />
                <stop offset="100%" stop-color="transparent" />
            </radialGradient>
        </defs>

        <!-- Draw Map -->
        @for (int y = 0; y < GameInstance.Height; y++)
        {
            @for (int x = 0; x < GameInstance.Width; x++)
            {
                var tile = GameInstance.Map[x, y];
                if (tile == BlazorArcade.GameLogic.TileType.Wall)
                {
                    <rect x="@(x * BlockSize)" y="@(y * BlockSize)" width="@BlockSize" height="@BlockSize" fill="#1919A6" stroke="#0000FF" stroke-width="1" />
                }
                else if (tile == BlazorArcade.GameLogic.TileType.Dot)
                {
                    <circle cx="@(x * BlockSize + BlockSize / 2.0)" cy="@(y * BlockSize + BlockSize / 2.0)" r="3" fill="#FFB8AE" />
                }
                else if (tile == BlazorArcade.GameLogic.TileType.PowerPellet)
                {
                    <circle cx="@(x * BlockSize + BlockSize / 2.0)" cy="@(y * BlockSize + BlockSize / 2.0)" r="8" fill="url(#power-pellet)" class="@(IsPowerPelletBlinking ? "blink" : "")" />
                }
                else if (tile == BlazorArcade.GameLogic.TileType.GhostGate)
                {
                    <rect x="@(x * BlockSize)" y="@(y * BlockSize + BlockSize/2.0 - 2)" width="@BlockSize" height="4" fill="#FFB8AE" />
                }
            }
        }

        <!-- Draw Ghosts -->
        @foreach (var ghost in GameInstance.Ghosts)
        {
            string color = ghost.State == BlazorArcade.GameLogic.GhostState.Frightened ? (IsFrightenedBlinking && ghost.FrightenedTimer < 15 ? "white" : "blue") : ghost.Color;
            
            if (ghost.State == BlazorArcade.GameLogic.GhostState.Eaten)
            {
                // Just draw eyes if eaten
                <circle cx="@(ghost.X * BlockSize + BlockSize * 0.3)" cy="@(ghost.Y * BlockSize + BlockSize * 0.4)" r="3" fill="white" />
                <circle cx="@(ghost.X * BlockSize + BlockSize * 0.7)" cy="@(ghost.Y * BlockSize + BlockSize * 0.4)" r="3" fill="white" />
                <circle cx="@(ghost.X * BlockSize + BlockSize * 0.3)" cy="@(ghost.Y * BlockSize + BlockSize * 0.4)" r="1" fill="blue" />
                <circle cx="@(ghost.X * BlockSize + BlockSize * 0.7)" cy="@(ghost.Y * BlockSize + BlockSize * 0.4)" r="1" fill="blue" />
            }
            else
            {
                // Ghost Body SVG Path
                double gx = ghost.X * BlockSize;
                double gy = ghost.Y * BlockSize;
                double w = BlockSize;
                double h = BlockSize;
                
                string ghostPath = $"M {gx},{gy+h} " +
                                   $"L {gx},{gy+h/2} " +
                                   $"A {w/2},{h/2} 0 0,1 {gx+w},{gy+h/2} " +
                                   $"L {gx+w},{gy+h} " +
                                   $"L {gx+w*0.8},{gy+h*0.8} " +
                                   $"L {gx+w*0.6},{gy+h} " +
                                   $"L {gx+w*0.4},{gy+h*0.8} " +
                                   $"L {gx+w*0.2},{gy+h} " +
                                   $"Z";
                
                <path d="@ghostPath" fill="@color" />
                
                // Eyes
                if (ghost.State != BlazorArcade.GameLogic.GhostState.Frightened)
                {
                    <circle cx="@(gx + w * 0.3)" cy="@(gy + h * 0.4)" r="3" fill="white" />
                    <circle cx="@(gx + w * 0.7)" cy="@(gy + h * 0.4)" r="3" fill="white" />
                    <circle cx="@(gx + w * 0.3)" cy="@(gy + h * 0.4)" r="1" fill="blue" />
                    <circle cx="@(gx + w * 0.7)" cy="@(gy + h * 0.4)" r="1" fill="blue" />
                }
                else
                {
                    // Frightened face
                    <rect x="@(gx + w * 0.2)" y="@(gy + h * 0.4)" width="4" height="4" fill="pink" />
                    <rect x="@(gx + w * 0.6)" y="@(gy + h * 0.4)" width="4" height="4" fill="pink" />
                    <path d="M @(gx + w * 0.2),@(gy + h * 0.7) L @(gx + w * 0.3),@(gy + h * 0.6) L @(gx + w * 0.5),@(gy + h * 0.7) L @(gx + w * 0.7),@(gy + h * 0.6) L @(gx + w * 0.8),@(gy + h * 0.7)" stroke="pink" stroke-width="1.5" fill="none" />
                }
            }
        }

        <!-- Draw Pacman -->
        @{
            double px = GameInstance.Player.X * BlockSize + BlockSize / 2.0;
            double py = GameInstance.Player.Y * BlockSize + BlockSize / 2.0;
            double pr = BlockSize / 2.0 * 0.8; // Radius slightly smaller than block
            
            // Rotation based on direction
            int rotation = 0;
            switch (GameInstance.Player.CurrentDirection)
            {
                case BlazorArcade.GameLogic.Direction.Up: rotation = 270; break;
                case BlazorArcade.GameLogic.Direction.Down: rotation = 90; break;
                case BlazorArcade.GameLogic.Direction.Left: rotation = 180; break;
                case BlazorArcade.GameLogic.Direction.Right: rotation = 0; break;
            }

            // Animate mouth opening
            double mouthAngle = IsMouthOpen ? 45 : 10;
            
            // Convert angle to coordinates for the SVG arc
            // SVG Arc logic is a bit complex, but standard Pacman can be drawn with an arc.
            // Using a simpler approach: A circle with a polygon mask or two arcs.
            // Let's use a path to draw Pacman
            
            double startX = px + pr * Math.Cos(mouthAngle * Math.PI / 180.0);
            double startY = py - pr * Math.Sin(mouthAngle * Math.PI / 180.0);
            double endX = px + pr * Math.Cos(-mouthAngle * Math.PI / 180.0);
            double endY = py - pr * Math.Sin(-mouthAngle * Math.PI / 180.0);
            
            // Transform for rotation
            string transform = $"rotate({rotation}, {px}, {py})";
            
            // If completely closed mouth, just draw a circle to avoid path issues
            if (mouthAngle < 5)
            {
                 <circle cx="@px" cy="@py" r="@pr" fill="yellow" />
            }
            else
            {
                <path d="M @px,@py L @startX,@startY A @pr,@pr 0 1,0 @endX,@endY Z" fill="yellow" transform="@transform" />
            }
        }
    </svg>
</div>
